# Backend environment variables (example)
# Replace values and keep secrets out of source control

# JWT secret for signing tokens
JWT_SECRET=your_jwt_secret_here

# Database connection (example)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=secret
DB_NAME=askar_stone

# Google OAuth (must match values in Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# EXACT redirect URI configured in Google Cloud -> e.g. http://localhost:3000/auth/google-callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google-callback

# Frontend URL for emails / links (optional)
FRONTEND_URL=http://localhost:3000
