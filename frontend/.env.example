# Frontend environment variables (example)
# Do NOT put client secrets here.

# Backend API base (must include /api if backend serves API under /api)
REACT_APP_API_URL=http://localhost:5000/api

# Optional: precomputed Google auth URL if you prefer
# REACT_APP_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth?client_id=...&redirect_uri=...&response_type=code&scope=openid%20email%20profile
